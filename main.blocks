<xml xmlns="https://developers.google.com/blockly/xml"><variables></variables><block type="pxt-on-start" id="~1!Ue6#U|+wjXN~_$_/)" x="20" y="20"><statement name="HANDLER"><block type="typescript_statement" id="_|hiwh#hYl{J1,IwT3i)"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="enum NeoPixelColors {" line1="    //% block=Rot" line2="    Rot = 0xFF0000," line3="    //% block=Orange" line4="    Orange = 0xFFA500," line5="    //% block=Gelb" line6="    Gelb = 0xFFFF00," line7="    //% block=Gruen" line8="    Gruen = 0x00FF00," line9="    //% block=Blau" line10="    Blau = 0x0000FF," line11="    //% block=violett" line12="    Violett = 0x8a2be2," line13="    //% block=weiss" line14="    Weiss = 0xFFFFFF," line15="    //% block=schwarz" line16="    Schwwarz = 0x000000" line17="}" numlines="18"></mutation><next><block type="typescript_statement" id="6^snUyDrbh9bmxK0ks4m"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="enum NeoPixelMode {" line1="    //% block=&quot;RGB (GRB format)&quot;" line2="    RGB = 1," line3="    //% block=&quot;RGB+W&quot;" line4="    RGBW = 2," line5="    //% block=&quot;RGB (RGB format)&quot;" line6="    RGB_RGB = 3" line7="}" numlines="8"></mutation><next><block type="typescript_statement" id="jrzu.P8IC1hOZKja0[Re"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace neopixel {" line1="    /**" line2="     * A NeoPixel strip" line3="     */" line4="    export class Strip {" line5="        buf: Buffer;" line6="        pin: DigitalPin;" line7="        // TODO: encode as bytes instead of 32bit" line8="        brightness: number;" line9="        start: number; // start offset in LED strip" line10="        _length: number; // number of LEDs" line11="        _mode: NeoPixelMode;" line12="        _matrixWidth: number; // number of leds in a matrix - if any" line13="" line14="        /**" line15="         * Shows all LEDs to a given color (range 0-255 for r, g, b)." line16="         * @param rgb RGB color of the LED" line17="         */" line18="        //% blockId=&quot;neopixel_set_strip_farbe&quot; block=&quot;%strip|zeige farbe %rgb=neopixel_colors&quot;" line19="        //% strip.defl=strip" line20="        //% weight=85 blockGap=8" line21="        //% parts=&quot;neopixel&quot;" line22="        showColor(rgb: number) {" line23="            rgb = rgb &gt;&gt; 0;" line24="            this.setAllRGB(rgb);" line25="            this.show();" line26="        }" line27="" line28="        /**" line29="         * Shows a rainbow pattern on all LEDs." line30="         * @param startHue the start hue value for the rainbow, eg: 1" line31="         * @param endHue the end hue value for the rainbow, eg: 360" line32="         */" line33="        //% blockId=&quot;neopixel_set_strip_rainbow&quot; block=&quot;%strip|zeige regenbogen von %startHue|bis %endHue&quot;" line34="        //% strip.defl=strip" line35="        //% weight=85 blockGap=8" line36="        //% parts=&quot;neopixel&quot;" line37="        showRainbow(startHue: number = 1, endHue: number = 360) {" line38="            if (this._length &lt;= 0) return;" line39="" line40="            startHue = startHue &gt;&gt; 0;" line41="            endHue = endHue &gt;&gt; 0;" line42="            const saturation = 100;" line43="            const luminance = 50;" line44="            const steps = this._length;" line45="            const direction = HueInterpolationDirection.Clockwise;" line46="" line47="            //hue" line48="            const h1 = startHue;" line49="            const h2 = endHue;" line50="            const hDistCW = ((h2 + 360) - h1) % 360;" line51="            const hStepCW = Math.idiv((hDistCW * 100), steps);" line52="            const hDistCCW = ((h1 + 360) - h2) % 360;" line53="            const hStepCCW = Math.idiv(-(hDistCCW * 100), steps);" line54="            let hStep: number;" line55="            if (direction === HueInterpolationDirection.Clockwise) {" line56="                hStep = hStepCW;" line57="            } else if (direction === HueInterpolationDirection.CounterClockwise) {" line58="                hStep = hStepCCW;" line59="            } else {" line60="                hStep = hDistCW &lt; hDistCCW ? hStepCW : hStepCCW;" line61="            }" line62="            const h1_100 = h1 * 100; //we multiply by 100 so we keep more accurate results while doing interpolation" line63="" line64="            //sat" line65="            const s1 = saturation;" line66="            const s2 = saturation;" line67="            const sDist = s2 - s1;" line68="            const sStep = Math.idiv(sDist, steps);" line69="            const s1_100 = s1 * 100;" line70="" line71="            //lum" line72="            const l1 = luminance;" line73="            const l2 = luminance;" line74="            const lDist = l2 - l1;" line75="            const lStep = Math.idiv(lDist, steps);" line76="            const l1_100 = l1 * 100" line77="" line78="            //interpolate" line79="            if (steps === 1) {" line80="                this.setPixelColor(0, hsl(h1 + hStep, s1 + sStep, l1 + lStep))" line81="            } else {" line82="                this.setPixelColor(0, hsl(startHue, saturation, luminance));" line83="                for (let i = 1; i &lt; steps - 1; i++) {" line84="                    const h = Math.idiv((h1_100 + i * hStep), 100) + 360;" line85="                    const s = Math.idiv((s1_100 + i * sStep), 100);" line86="                    const l = Math.idiv((l1_100 + i * lStep), 100);" line87="                    this.setPixelColor(i, hsl(h, s, l));" line88="                }" line89="                this.setPixelColor(steps - 1, hsl(endHue, saturation, luminance));" line90="            }" line91="            this.show();" line92="        }" line93="" line94="        /**" line95="         * Displays a vertical bar graph based on the `value` and `high` value." line96="         * If `high` is 0, the chart gets adjusted automatically." line97="         * @param value current value to plot" line98="         * @param high maximum value, eg: 255" line99="         */" line100="        //% weight=84" line101="        //% blockId=neopixel_zeige_säulen_diagramm block=&quot;%strip|zeige säulendiagramm von %value|bis %high&quot;" line102="        //% strip.defl=strip" line103="        //% icon=&quot;\uf080&quot;" line104="        //% parts=&quot;neopixel&quot;" line105="        showBarGraph(value: number, high: number): void {" line106="            if (high &lt;= 0) {" line107="                this.clear();" line108="                this.setPixelColor(0, NeoPixelColors.Gelb);" line109="                this.show();" line110="                return;" line111="            }" line112="" line113="            value = Math.abs(value);" line114="            const n = this._length;" line115="            const n1 = n - 1;" line116="            let v = Math.idiv((value * n), high);" line117="            if (v == 0) {" line118="                this.setPixelColor(0, 0x666600);" line119="                for (let j = 1; j &lt; n; ++j)" line120="                    this.setPixelColor(j, 0);" line121="            } else {" line122="                for (let k = 0; k &lt; n; ++k) {" line123="                    if (k &lt;= v) {" line124="                        const b = Math.idiv(k * 255, n1);" line125="                        this.setPixelColor(k, neopixel.rgb(b, 0, 255 - b));" line126="                    }" line127="                    else this.setPixelColor(k, 0);" line128="                }" line129="            }" line130="            this.show();" line131="        }" line132="" line133="        /**" line134="         * Set LED to a given color (range 0-255 for r, g, b)." line135="         * You need to call ``show`` to make the changes visible." line136="         * @param pixeloffset position of the NeoPixel in the strip" line137="         * @param rgb RGB color of the LED" line138="         */" line139="        //% blockId=&quot;setze_pixel_farbe&quot; block=&quot;%strip|setze Pixel an %pixeloffset|auf Farbe %rgb=neopixel_colors&quot;" line140="        //% strip.defl=strip" line141="        //% blockGap=8" line142="        //% weight=80" line143="        //% parts=&quot;neopixel&quot; advanced=true" line144="        setPixelColor(pixeloffset: number, rgb: number): void {" line145="            this.setPixelRGB(pixeloffset &gt;&gt; 0, rgb &gt;&gt; 0);" line146="        }" line147="" line148="        /**" line149="         * Sets the number of pixels in a matrix shaped strip" line150="         * @param width number of pixels in a row" line151="         */" line152="        //% blockId=neopixel_setze_matrix_länge block=&quot;%strip|setze matrix länge auf %width&quot;" line153="        //% strip.defl=strip" line154="        //% blockGap=8" line155="        //% weight=5" line156="        //% parts=&quot;neopixel&quot; advanced=true" line157="        setMatrixWidth(width: number) {" line158="            this._matrixWidth = Math.min(this._length, width &gt;&gt; 0);" line159="        }" line160="" line161="        /**" line162="         * Set LED to a given color (range 0-255 for r, g, b) in a matrix shaped strip" line163="         * You need to call ``show`` to make the changes visible." line164="         * @param x horizontal position" line165="         * @param y horizontal position" line166="         * @param rgb RGB color of the LED" line167="         */" line168="        //% blockId=&quot;neopixel_set_matrix_color&quot; block=&quot;%strip|setze matrix farbe an x %x|y %y|bis %rgb=neopixel_colors&quot;" line169="        //% strip.defl=strip" line170="        //% weight=4" line171="        //% parts=&quot;neopixel&quot; advanced=true" line172="        setMatrixColor(x: number, y: number, rgb: number) {" line173="            if (this._matrixWidth &lt;= 0) return; // not a matrix, ignore" line174="            x = x &gt;&gt; 0;" line175="            y = y &gt;&gt; 0;" line176="            rgb = rgb &gt;&gt; 0;" line177="            const cols = Math.idiv(this._length, this._matrixWidth);" line178="            if (x &lt; 0 || x &gt;= this._matrixWidth || y &lt; 0 || y &gt;= cols) return;" line179="            let m = x + y * this._matrixWidth;" line180="            this.setPixelColor(m, rgb);" line181="        }" line182="" line183="        /**" line184="         * For NeoPixels with RGB+W LEDs, set the white LED brightness. This only works for RGB+W NeoPixels." line185="         * @param pixeloffset position of the LED in the strip" line186="         * @param white brightness of the white LED" line187="         */" line188="        //% blockId=&quot;neopixel_set_pixel_white&quot; block=&quot;%strip|setze weisse LED an %pixeloffset|auf %white&quot;" line189="        //% strip.defl=strip" line190="        //% blockGap=8" line191="        //% weight=80" line192="        //% parts=&quot;neopixel&quot; advanced=true" line193="        setPixelWhiteLED(pixeloffset: number, white: number): void {" line194="            if (this._mode === NeoPixelMode.RGBW) {" line195="                this.setPixelW(pixeloffset &gt;&gt; 0, white &gt;&gt; 0);" line196="            }" line197="        }" line198="" line199="        /**" line200="         * Send all the changes to the strip." line201="         */" line202="        //% blockId=&quot;neopixel_zeige&quot; block=&quot;%strip|zeige&quot; blockGap=8" line203="        //% strip.defl=strip" line204="        //% weight=79" line205="        //% parts=&quot;neopixel&quot;" line206="        show() {" line207="            // only supported in beta" line208="            // ws2812b.setBufferMode(this.pin, this._mode);" line209="            //ws2812b.sendBuffer(this.buf, this.pin);" line210="        }" line211="" line212="        /**" line213="         * Turn off all LEDs." line214="         * You need to call ``show`` to make the changes visible." line215="         */" line216="        //% blockId=&quot;neopixel_clear&quot; block=&quot;%strip|löschen&quot;" line217="        //% strip.defl=strip" line218="        //% weight=76" line219="        //% parts=&quot;neopixel&quot;" line220="        clear(): void {" line221="            const stride = this._mode === NeoPixelMode.RGBW ? 4 : 3;" line222="            this.buf.fill(0, this.start * stride, this._length * stride);" line223="        }" line224="" line225="        /**" line226="         * Gets the number of pixels declared on the strip" line227="         */" line228="        //% blockId=&quot;neopixel_länge&quot; block=&quot;%strip|länge&quot; blockGap=8" line229="        //% strip.defl=strip" line230="        //% weight=60 advanced=true" line231="        length() {" line232="            return this._length;" line233="        }" line234="" line235="        /**" line236="         * Set the brightness of the strip. This flag only applies to future operation." line237="         * @param brightness a measure of LED brightness in 0-255. eg: 255" line238="         */" line239="        //% blockId=&quot;neopixel_setze_helligkeit&quot; block=&quot;%strip|setze helligkeit auf %brightness&quot; blockGap=8" line240="        //% strip.defl=strip" line241="        //% weight=59" line242="        //% parts=&quot;neopixel&quot; advanced=true" line243="        setBrightness(brightness: number): void {" line244="            this.brightness = brightness &amp; 0xff;" line245="        }" line246="" line247="" line248="        /**" line249="         * Create a range of LEDs." line250="         * @param start offset in the LED strip to start the range" line251="         * @param length number of LEDs in the range. eg: 4" line252="         */" line253="        //% weight=89" line254="        //% blockId=&quot;neopixel_range&quot; block=&quot;%strip|range von %start|mit %length|leds&quot;" line255="        //% strip.defl=strip" line256="        //% parts=&quot;neopixel&quot;" line257="        //% blockSetVariable=range" line258="        range(start: number, length: number): Strip {" line259="            start = start &gt;&gt; 0;" line260="            length = length &gt;&gt; 0;" line261="            let strip = new Strip();" line262="            strip.buf = this.buf;" line263="            strip.pin = this.pin;" line264="            strip.brightness = this.brightness;" line265="            strip.start = this.start + Math.clamp(0, this._length - 1, start);" line266="            strip._length = Math.clamp(0, this._length - (strip.start - this.start), length);" line267="            strip._matrixWidth = 0;" line268="            strip._mode = this._mode;" line269="            return strip;" line270="        }" line271="" line272="        /**" line273="         * Shift LEDs forward and clear with zeros." line274="         * You need to call ``show`` to make the changes visible." line275="         * @param offset number of pixels to shift forward, eg: 1" line276="         */" line277="        //% blockId=&quot;neopixel_shift&quot; block=&quot;%strip|verschiebe pixel um %offset&quot; blockGap=8" line278="        //% strip.defl=strip" line279="        //% weight=40" line280="        //% parts=&quot;neopixel&quot;" line281="        shift(offset: number = 1): void {" line282="            offset = offset &gt;&gt; 0;" line283="            const stride2 = this._mode === NeoPixelMode.RGBW ? 4 : 3;" line284="            this.buf.shift(-offset * stride2, this.start * stride2, this._length * stride2)" line285="        }" line286="" line287="        /**" line288="         * Rotate LEDs forward." line289="         * You need to call ``show`` to make the changes visible." line290="         * @param offset number of pixels to rotate forward, eg: 1" line291="         */" line292="        //% blockId=&quot;neopixel_rotate&quot; block=&quot;%strip|rotiere pixel um %offset&quot; blockGap=8" line293="        //% strip.defl=strip" line294="        //% weight=39" line295="        //% parts=&quot;neopixel&quot;" line296="        rotate(offset: number = 1): void {" line297="            offset = offset &gt;&gt; 0;" line298="            const stride3 = this._mode === NeoPixelMode.RGBW ? 4 : 3;" line299="            this.buf.rotate(-offset * stride3, this.start * stride3, this._length * stride3)" line300="        }" line301="" line302="        /**" line303="         * Set the pin where the neopixel is connected, defaults to P0." line304="         */" line305="        //% weight=10" line306="        //% parts=&quot;neopixel&quot; advanced=true" line307="        setPin(pin: DigitalPin): void {" line308="            this.pin = pin;" line309="            pins.digitalWritePin(this.pin, 0);" line310="            // don't yield to avoid races on initialization" line311="        }" line312="" line313="        /**" line314="         * Estimates the electrical current (mA) consumed by the current light configuration." line315="         */" line316="        //% weight=9 blockId=neopixel_power block=&quot;%strip|power (mA)&quot;" line317="        //% strip.defl=strip" line318="        //% advanced=true" line319="        power(): number {" line320="            const stride4 = this._mode === NeoPixelMode.RGBW ? 4 : 3;" line321="            const end = this.start + this._length;" line322="            let p = 0;" line323="            for (let o = this.start; o &lt; end; ++o) {" line324="                const ledoffset = o * stride4;" line325="                for (let q = 0; q &lt; stride4; ++q) {" line326="                    p += this.buf[o + q];" line327="                }" line328="            }" line329="            return Math.idiv(this.length() * 7, 10) /* 0.7mA per neopixel */" line330="                + Math.idiv(p * 480, 10000); /* rought approximation */" line331="        }" line332="" line333="        private setBufferRGB(offset: number, red: number, green: number, blue: number): void {" line334="            if (this._mode === NeoPixelMode.RGB_RGB) {" line335="                this.buf[offset + 0] = red;" line336="                this.buf[offset + 1] = green;" line337="            } else {" line338="                this.buf[offset + 0] = green;" line339="                this.buf[offset + 1] = red;" line340="            }" line341="            this.buf[offset + 2] = blue;" line342="        }" line343="" line344="        private setAllRGB(rgb: number) {" line345="            let red = unpackR(rgb);" line346="            let green = unpackG(rgb);" line347="            let blue = unpackB(rgb);" line348="" line349="            const br = this.brightness;" line350="            if (br &lt; 255) {" line351="                red = (red * br) &gt;&gt; 8;" line352="                green = (green * br) &gt;&gt; 8;" line353="                blue = (blue * br) &gt;&gt; 8;" line354="            }" line355="            const end2 = this.start + this._length;" line356="            const stride5 = this._mode === NeoPixelMode.RGBW ? 4 : 3;" line357="            for (let r = this.start; r &lt; end2; ++r) {" line358="                this.setBufferRGB(r * stride5, red, green, blue)" line359="            }" line360="        }" line361="        private setAllW(white: number) {" line362="            if (this._mode !== NeoPixelMode.RGBW)" line363="                return;" line364="" line365="            let br2 = this.brightness;" line366="            if (br2 &lt; 255) {" line367="                white = (white * br2) &gt;&gt; 8;" line368="            }" line369="            let buf = this.buf;" line370="            let end3 = this.start + this._length;" line371="            for (let t = this.start; t &lt; end3; ++t) {" line372="                let ledoffset2 = t * 4;" line373="                buf[ledoffset2 + 3] = white;" line374="            }" line375="        }" line376="        private setPixelRGB(pixeloffset: number, rgb: number): void {" line377="            if (pixeloffset &lt; 0" line378="                || pixeloffset &gt;= this._length)" line379="                return;" line380="" line381="            let stride6 = this._mode === NeoPixelMode.RGBW ? 4 : 3;" line382="            pixeloffset = (pixeloffset + this.start) * stride6;" line383="" line384="            let red2 = unpackR(rgb);" line385="            let green2 = unpackG(rgb);" line386="            let blue2 = unpackB(rgb);" line387="" line388="            let br3 = this.brightness;" line389="            if (br3 &lt; 255) {" line390="                red2 = (red2 * br3) &gt;&gt; 8;" line391="                green2 = (green2 * br3) &gt;&gt; 8;" line392="                blue2 = (blue2 * br3) &gt;&gt; 8;" line393="            }" line394="            this.setBufferRGB(pixeloffset, red2, green2, blue2)" line395="        }" line396="        private setPixelW(pixeloffset: number, white: number): void {" line397="            if (this._mode !== NeoPixelMode.RGBW)" line398="                return;" line399="" line400="            if (pixeloffset &lt; 0" line401="                || pixeloffset &gt;= this._length)" line402="                return;" line403="" line404="            pixeloffset = (pixeloffset + this.start) * 4;" line405="" line406="            let br4 = this.brightness;" line407="            if (br4 &lt; 255) {" line408="                white = (white * br4) &gt;&gt; 8;" line409="            }" line410="            let buf2 = this.buf;" line411="            buf2[pixeloffset + 3] = white;" line412="        }" line413="    }" line414="" line415="    /**" line416="     * Create a new NeoPixel driver for `numleds` LEDs." line417="     * @param pin the pin where the neopixel is connected." line418="     * @param numleds number of leds in the strip, eg: 24,30,60,64" line419="     */" line420="    //% blockId=&quot;neopixel_create&quot; block=&quot;NeoPixel an Pin %pin|mit %numleds|leds als %mode&quot;" line421="    //% weight=90 blockGap=8" line422="    //% parts=&quot;neopixel&quot;" line423="    //% trackArgs=0,2" line424="    //% blockSetVariable=strip" line425="    export function create(pin: DigitalPin, numleds: number, mode: NeoPixelMode): Strip {" line426="        let strip2 = new Strip();" line427="        let stride7 = mode === NeoPixelMode.RGBW ? 4 : 3;" line428="        strip2.buf = pins.createBuffer(numleds * stride7);" line429="        strip2.start = 0;" line430="        strip2._length = numleds;" line431="        strip2._mode = mode || NeoPixelMode.RGB;" line432="        strip2._matrixWidth = 0;" line433="        strip2.setBrightness(128)" line434="        strip2.setPin(pin)" line435="        return strip2;" line436="    }" line437="" line438="    /**" line439="     * Converts red, green, blue channels into a RGB color" line440="     * @param red value of the red channel between 0 and 255. eg: 255" line441="     * @param green value of the green channel between 0 and 255. eg: 255" line442="     * @param blue value of the blue channel between 0 and 255. eg: 255" line443="     */" line444="    //% weight=1" line445="    //% blockId=&quot;neopixel_rgb&quot; block=&quot;red %red|green %green|blue %blue&quot;" line446="    //% advanced=true" line447="    export function rgb(red: number, green: number, blue: number): number {" line448="        return packRGB(red, green, blue);" line449="    }" line450="" line451="    /**" line452="     * Gets the RGB value of a known color" line453="    */" line454="    //% weight=2 blockGap=8" line455="    //% blockId=&quot;neopixel_colors&quot; block=&quot;%Farbe&quot;" line456="    //% advanced=true" line457="    export function colors(color: NeoPixelColors): number {" line458="        return color;" line459="    }" line460="" line461="    function packRGB(a: number, b: number, c: number): number {" line462="        return ((a &amp; 0xFF) &lt;&lt; 16) | ((b &amp; 0xFF) &lt;&lt; 8) | (c &amp; 0xFF);" line463="    }" line464="    function unpackR(rgb: number): number {" line465="        let u = (rgb &gt;&gt; 16) &amp; 0xFF;" line466="        return u;" line467="    }" line468="    function unpackG(rgb: number): number {" line469="        let g = (rgb &gt;&gt; 8) &amp; 0xFF;" line470="        return g;" line471="    }" line472="    function unpackB(rgb: number): number {" line473="        let c = (rgb) &amp; 0xFF;" line474="        return c;" line475="    }" line476="" line477="    /**" line478="     * Converts a hue saturation luminosity value into a RGB color" line479="     * @param h hue from 0 to 360" line480="     * @param s saturation from 0 to 99" line481="     * @param l luminosity from 0 to 99" line482="     */" line483="    //% blockId=neopixelHSL block=&quot;hue %h|saturation %s|luminosity %l&quot;" line484="    export function hsl(h: number, s: number, l: number): number {" line485="        h = Math.round(h);" line486="        s = Math.round(s);" line487="        l = Math.round(l);" line488="" line489="        h = h % 360;" line490="        s = Math.clamp(0, 99, s);" line491="        l = Math.clamp(0, 99, l);" line492="        let d = Math.idiv((((100 - Math.abs(2 * l - 100)) * s) &lt;&lt; 8), 10000); //chroma, [0,255]" line493="        let h12 = Math.idiv(h, 60);//[0,6]" line494="        let h22 = Math.idiv((h - h12 * 60) * 256, 60);//[0,255]" line495="        let temp = Math.abs((((h12 % 2) &lt;&lt; 8) + h22) - 256);" line496="        let x = (d * (256 - (temp))) &gt;&gt; 8;//[0,255], second largest component of this color" line497="        let r$: number;" line498="        let g$: number;" line499="        let b$: number;" line500="        if (h12 == 0) {" line501="            r$ = d; g$ = x; b$ = 0;" line502="        } else if (h12 == 1) {" line503="            r$ = x; g$ = d; b$ = 0;" line504="        } else if (h12 == 2) {" line505="            r$ = 0; g$ = d; b$ = x;" line506="        } else if (h12 == 3) {" line507="            r$ = 0; g$ = x; b$ = d;" line508="        } else if (h12 == 4) {" line509="            r$ = x; g$ = 0; b$ = d;" line510="        } else if (h12 == 5) {" line511="            r$ = d; g$ = 0; b$ = x;" line512="        }" line513="        let w = Math.idiv((Math.idiv((l * 2 &lt;&lt; 8), 100) - d), 2);" line514="        let a = r$ + w;" line515="        let e = g$ + w;" line516="        let f = b$ + w;" line517="        return packRGB(a, e, f);" line518="    }" line519="" line520="    export enum HueInterpolationDirection {" line521="        Clockwise," line522="        CounterClockwise," line523="        Shortest" line524="    }" line525="}" numlines="526"></mutation><next><block type="typescript_statement" id="{hvc/kWY.jMJV^GN8QJc"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace I2C_LCD1602 {" line1="    let i2cAddr: number // 0x3F: PCF8574A, 0x27: PCF8574" line2="    let BK: number      // backlight control" line3="    let RS: number      // command/data" line4="" line5="    // set LCD reg" line6="    function setreg(d: number) {" line7="        pins.i2cWriteNumber(i2cAddr, d, NumberFormat.Int8LE)" line8="        basic.pause(1)" line9="    }" line10="" line11="    // send data to I2C bus" line12="    function set(d: number) {" line13="        d = d &amp; 0xF0" line14="        d = d + BK + RS" line15="        setreg(d)" line16="        setreg(d + 4)" line17="        setreg(d)" line18="    }" line19="" line20="    // send command" line21="    function cmd(d: number) {" line22="        RS = 0" line23="        set(d)" line24="        set(d &lt;&lt; 4)" line25="    }" line26="" line27="    // send data" line28="    function dat(d: number) {" line29="        RS = 1" line30="        set(d)" line31="        set(d &lt;&lt; 4)" line32="    }" line33="" line34="    // auto get LCD address" line35="    function AutoAddr() {" line36="        let k2 = true" line37="        let addr = 0x20" line38="        let d1 = 0, d2 = 0" line39="        while (k2 &amp;&amp; (addr &lt; 0x28)) {" line40="            pins.i2cWriteNumber(addr, -1, NumberFormat.Int32LE)" line41="            d1 = pins.i2cReadNumber(addr, NumberFormat.Int8LE) % 16" line42="            pins.i2cWriteNumber(addr, 0, NumberFormat.Int16LE)" line43="            d2 = pins.i2cReadNumber(addr, NumberFormat.Int8LE)" line44="            if ((d1 == 7) &amp;&amp; (d2 == 0)) k2 = false" line45="            else addr += 1" line46="        }" line47="        if (!k2) return addr" line48="" line49="        addr = 0x38" line50="        while (k2 &amp;&amp; (addr &lt; 0x40)) {" line51="            pins.i2cWriteNumber(addr, -1, NumberFormat.Int32LE)" line52="            d1 = pins.i2cReadNumber(addr, NumberFormat.Int8LE) % 16" line53="            pins.i2cWriteNumber(addr, 0, NumberFormat.Int16LE)" line54="            d2 = pins.i2cReadNumber(addr, NumberFormat.Int8LE)" line55="            if ((d1 == 7) &amp;&amp; (d2 == 0)) k2 = false" line56="            else addr += 1" line57="        }" line58="        if (!k2) return addr" line59="        else return 0" line60="" line61="    }" line62="" line63="    /**" line64="     * initial LCD, set I2C address. Address is 39/63 for PCF8574/PCF8574A" line65="     * @param Addr is i2c address for LCD, eg: 0, 39, 63. 0 is auto find address" line66="     */" line67="    //% blockId=&quot;I2C_LCD1620_SET_ADDRESS&quot; block=&quot;LCD initialisieren mit Adresse %addr&quot;" line68="    //% weight=100 blockGap=8" line69="    //% parts=LCD1602_I2C trackArgs=0" line70="    export function LcdInit(Addr: number) {" line71="        if (Addr == 0) i2cAddr = AutoAddr()" line72="        else i2cAddr = Addr" line73="        BK = 8" line74="        RS = 0" line75="        cmd(0x33)       // set 4bit mode" line76="        basic.pause(5)" line77="        set(0x30)" line78="        basic.pause(5)" line79="        set(0x20)" line80="        basic.pause(5)" line81="        cmd(0x28)       // set mode" line82="        cmd(0x0C)" line83="        cmd(0x06)" line84="        cmd(0x01)       // clear" line85="    }" line86="" line87="    /**" line88="     * show a number in LCD at given position" line89="     * @param n is number will be show, eg: 10, 100, 200" line90="     * @param x is LCD column position, eg: 0" line91="     * @param y is LCD row position, eg: 0" line92="     */" line93="    //% blockId=&quot;I2C_LCD1620_SHOW_NUMBER&quot; block=&quot;zeige Zahl%n|at x %x|y %y&quot;" line94="    //% weight=90 blockGap=8" line95="    //% x.min=0 x.max=15" line96="    //% y.min=0 y.max=1" line97="    //% parts=LCD1602_I2C trackArgs=0" line98="    export function ShowNumber(n: number, x: number, y: number): void {" line99="        let s3 = n.toString()" line100="        ShowString(s3, x, y)" line101="    }" line102="" line103="    /**" line104="     * show a string in LCD at given position" line105="     * @param s is string will be show, eg: &quot;Hello&quot;" line106="     * @param x is LCD column position, [0 - 15], eg: 0" line107="     * @param y is LCD row position, [0 - 1], eg: 0" line108="     */" line109="    //% blockId=&quot;I2C_LCD1620_SHOW_STRING&quot; block=&quot;zeige Wort %s|at x %x|y %y&quot;" line110="    //% weight=90 blockGap=8" line111="    //% x.min=0 x.max=15" line112="    //% y.min=0 y.max=1" line113="    //% parts=LCD1602_I2C trackArgs=0" line114="    export function ShowString(s: string, x: number, y: number): void {" line115="        let a2: number" line116="" line117="        if (y &gt; 0)" line118="            a2 = 0xC0" line119="        else" line120="            a2 = 0x80" line121="        a2 += x" line122="        cmd(a2)" line123="" line124="        for (let i2 = 0; i2 &lt; s.length; i2++) {" line125="            dat(s.charCodeAt(i2))" line126="        }" line127="    }" line128="" line129="    /**" line130="     * turn on LCD" line131="     */" line132="    //% blockId=&quot;I2C_LCD1620_ON&quot; block=&quot;LCD ein&quot;" line133="    //% weight=81 blockGap=8" line134="    //% parts=LCD1602_I2C trackArgs=0" line135="    export function on(): void {" line136="        cmd(0x0C)" line137="    }" line138="" line139="    /**" line140="     * turn off LCD" line141="     */" line142="    //% blockId=&quot;I2C_LCD1620_OFF&quot; block=&quot;LCD aus&quot;" line143="    //% weight=80 blockGap=8" line144="    //% parts=LCD1602_I2C trackArgs=0" line145="    export function off(): void {" line146="        cmd(0x08)" line147="    }" line148="" line149="    /**" line150="     * clear all display content" line151="     */" line152="    //% blockId=&quot;I2C_LCD1620_CLEAR&quot; block=&quot;leere LCD&quot;" line153="    //% weight=85 blockGap=8" line154="    //% parts=LCD1602_I2C trackArgs=0" line155="    export function clear(): void {" line156="        cmd(0x01)" line157="    }" line158="" line159="    /**" line160="     * turn on LCD backlight" line161="     */" line162="    //% blockId=&quot;I2C_LCD1620_BACKLIGHT_ON&quot; block=&quot;rückbeleuchtung ein&quot;" line163="    //% weight=71 blockGap=8" line164="    //% parts=LCD1602_I2C trackArgs=0" line165="    export function BacklightOn(): void {" line166="        BK = 8" line167="        cmd(0)" line168="    }" line169="" line170="    /**" line171="     * turn off LCD backlight" line172="     */" line173="    //% blockId=&quot;I2C_LCD1620_BACKLIGHT_OFF&quot; block=&quot;rückbeleuchtung aus&quot;" line174="    //% weight=70 blockGap=8" line175="    //% parts=LCD1602_I2C trackArgs=0" line176="    export function BacklightOff(): void {" line177="        BK = 0" line178="        cmd(0)" line179="    }" line180="" line181="    /**" line182="     * shift left" line183="     */" line184="    //% blockId=&quot;I2C_LCD1620_SHL&quot; block=&quot;verschiebe nach links&quot;" line185="    //% weight=61 blockGap=8" line186="    //% parts=LCD1602_I2C trackArgs=0" line187="    export function shl(): void {" line188="        cmd(0x18)" line189="    }" line190="" line191="    /**" line192="     * nach rechts" line193="     */" line194="    //% blockId=&quot;I2C_LCD1620_SHR&quot; block=&quot;verschiebe nach rechts&quot;" line195="    //% weight=60 blockGap=8" line196="    //% parts=LCD1602_I2C trackArgs=0" line197="    export function shr(): void {" line198="        cmd(0x1C)" line199="    }" line200="}" numlines="201"></mutation><next><block type="typescript_statement" id="K.}^Fvc_?kIZ6CaWQ6qG"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="enum DHTtype {" line1="    //% block=&quot;DHT11&quot;" line2="    DHT11," line3="    //% block=&quot;DHT22&quot;" line4="    DHT22," line5="}" numlines="6"></mutation><next><block type="typescript_statement" id="j!!~|(O8%fErL4X)a;l1"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="enum dataType {" line1="    //% block=&quot;feuchtigkeit&quot;" line2="    humidity," line3="    //% block=&quot;temperatur&quot;" line4="    temperature," line5="}" numlines="6"></mutation><next><block type="typescript_statement" id="6ZwQ7|_v3A~rxF914@pF"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="enum tempType {" line1="    //% block=&quot;Celsius (*C)&quot;" line2="    celsius," line3="    //% block=&quot;Fahrenheit (*F)&quot;" line4="    fahrenheit," line5="}" numlines="6"></mutation><next><block type="typescript_statement" id="pqr5G3M?%@X.3FV3gTwP"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace dht11_dht22 {" line1="" line2="    let _temperature: number = -999.0" line3="    let _humidity: number = -999.0" line4="    let _temptype: tempType = tempType.celsius" line5="    let _readSuccessful: boolean = false" line6="    let _sensorresponding: boolean = false" line7="" line8="    /**" line9="    * Query data from DHT11/DHT22 sensor. If you are using 4 pins/no PCB board versions, you'll need to pull up the data pin. " line10="    * It is also recommended to wait 1 (DHT11) or 2 (DHT22) seconds between each query." line11="    */" line12="    //% block=&quot;Daten von $DHT|Daten pin $dataPin|Serielle Ausgabe $serialOtput|warte 2 sekunden nach datenerhalt $wait&quot;" line13="    //% serialOtput.defl=false" line14="    //% wait.defl=true" line15="    //% blockExternalInputs=true" line16="    export function queryData(DHT: DHTtype, dataPin: DigitalPin, serialOtput: boolean, wait: boolean) {" line17="" line18="        //initialize" line19="        let startTime: number = 0" line20="        let endTime: number = 0" line21="        let checksum: number = 0" line22="        let checksumTmp: number = 0" line23="        let dataArray: boolean[] = []" line24="        let resultArray: number[] = []" line25="        let DHTstr: string = (DHT == DHTtype.DHT11) ? &quot;DHT11&quot; : &quot;DHT22&quot;" line26="" line27="        for (let index = 0; index &lt; 40; index++) dataArray.push(false)" line28="        for (let index2 = 0; index2 &lt; 5; index2++) resultArray.push(0)" line29="" line30="        _humidity = -999.0" line31="        _temperature = -999.0" line32="        _readSuccessful = false" line33="        _sensorresponding = false" line34="        startTime = input.runningTimeMicros()" line35="" line36="        //request data" line37="        pins.digitalWritePin(dataPin, 0) //begin protocol, pull down pin" line38="        basic.pause(18)" line39="" line40="" line41="" line42="        if (pins.digitalReadPin(dataPin) == 1) {" line43="            if (serialOtput) {" line44="                serial.writeLine(DHTstr + &quot; not responding!&quot;)" line45="                serial.writeLine(&quot;----------------------------------------&quot;)" line46="            }" line47="" line48="        } else {" line49="" line50="            _sensorresponding = true" line51="" line52="            while (pins.digitalReadPin(dataPin) == 0); //sensor response" line53="            while (pins.digitalReadPin(dataPin) == 1); //sensor response" line54="" line55="            //read data (5 bytes)" line56="            for (let index3 = 0; index3 &lt; 40; index3++) {" line57="                while (pins.digitalReadPin(dataPin) == 1);" line58="                while (pins.digitalReadPin(dataPin) == 0);" line59="                control.waitMicros(28)" line60="                //if sensor still pull up data pin after 28 us it means 1, otherwise 0" line61="                if (pins.digitalReadPin(dataPin) == 1) dataArray[index3] = true" line62="            }" line63="" line64="            endTime = input.runningTimeMicros()" line65="" line66="            //convert byte number array to integer" line67="            for (let index4 = 0; index4 &lt; 5; index4++)" line68="                for (let index22 = 0; index22 &lt; 8; index22++)" line69="                    if (dataArray[8 * index4 + index22]) resultArray[index4] += 2 ** (7 - index22)" line70="" line71="            //verify checksum" line72="            checksumTmp = resultArray[0] + resultArray[1] + resultArray[2] + resultArray[3]" line73="            checksum = resultArray[4]" line74="            if (checksumTmp &gt;= 512) checksumTmp -= 512" line75="            if (checksumTmp &gt;= 256) checksumTmp -= 256" line76="            if (checksum == checksumTmp) _readSuccessful = true" line77="" line78="            //read data if checksum ok" line79="            if (_readSuccessful) {" line80="                if (DHT == DHTtype.DHT11) {" line81="                    //DHT11" line82="                    _humidity = resultArray[0] + resultArray[1] / 100" line83="                    _temperature = resultArray[2] + resultArray[3] / 100" line84="                } else {" line85="                    //DHT22" line86="                    let temp_sign: number = 1" line87="                    if (resultArray[2] &gt;= 128) {" line88="                        resultArray[2] -= 128" line89="                        temp_sign = -1" line90="                    }" line91="                    _humidity = (resultArray[0] * 256 + resultArray[1]) / 10" line92="                    _temperature = (resultArray[2] * 256 + resultArray[3]) / 10 * temp_sign" line93="                }" line94="                if (_temptype == tempType.fahrenheit)" line95="                    _temperature = _temperature * 9 / 5 + 32" line96="            }" line97="" line98="            //serial output" line99="            if (serialOtput) {" line100="                serial.writeLine(DHTstr + &quot; query completed in &quot; + (endTime - startTime) + &quot; microseconds&quot;)" line101="                if (_readSuccessful) {" line102="                    serial.writeLine(&quot;Checksum ok&quot;)" line103="                    serial.writeLine(&quot;Humidity: &quot; + _humidity + &quot; %&quot;)" line104="                    serial.writeLine(&quot;Temperature: &quot; + _temperature + (_temptype == tempType.celsius ? &quot; *C&quot; : &quot; *F&quot;))" line105="                } else {" line106="                    serial.writeLine(&quot;Checksum error&quot;)" line107="                }" line108="                serial.writeLine(&quot;----------------------------------------&quot;)" line109="            }" line110="" line111="        }" line112="" line113="        //wait 2 sec after query if needed" line114="        if (wait) basic.pause(2000)" line115="" line116="    }" line117="" line118="    /**" line119="    * Read humidity/temperature data from lastest query of DHT11/DHT22" line120="    */" line121="    //% block=&quot;Lese $data&quot;" line122="    export function readData(data: dataType): number {" line123="        return data == dataType.humidity ? _humidity : _temperature" line124="    }" line125="" line126="    /**" line127="    * Select temperature type (Celsius/Fahrenheit)&quot;" line128="    */" line129="    //% block=&quot;Temperatur Typ: $temp&quot; advanced=true" line130="    export function selectTempType(temp: tempType) {" line131="        _temptype = temp" line132="    }" line133="" line134="    /**" line135="    * Determind if last query is successful (checksum ok)" line136="    */" line137="    //% block=&quot;Letzte Abfrage erfolgreich?&quot;" line138="    //export function readDataSuccessful(): boolean {" line139="        //return _readSuccessful" line140="    //}" line141="" line142="    /**" line143="    * Determind if sensor responded successfully (not disconnected, etc) in last query" line144="    */" line145="    //% block=&quot;Last query sensor responding?&quot; advanced=true" line146="    //export function sensorrResponding(): boolean {" line147="        //return _sensorresponding" line148="    //}" line149="" line150="}" numlines="151"></mutation></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></statement></block></xml>